{
  "name": "chat2api",
  "version": "3.0.0",
  "description": "ChatGPT to OpenAI API proxy — Go server",
  "scripts": {
    "start": "./run.sh",
    "build": "go build -o bin/chat2api ./cmd/chat2api",
    "test": "go test ./...",
    "dev": "go run ./cmd/chat2api",
    "codemod:validate": "npx codemod@latest workflow validate -w .codemod/workflow.yaml",
    "codemod:test": "npm --prefix .codemod test",
    "codemod:dry-run": "npx codemod@latest workflow run -w .codemod/workflow.yaml --target . --dry-run --no-interactive --allow-dirty",
    "codemod:run": "npx codemod@latest workflow run -w .codemod/workflow.yaml --target . --no-interactive --allow-dirty"
  },
  "dependencies": {
    "@koa/router": "^15.3.0",
    "axios": "^1.7.7",
    "eventsource-parser": "^3.0.6",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}