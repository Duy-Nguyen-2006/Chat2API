# ChatGPT access token (from https://chatgpt.com/api/auth/session)
CHATGPT_ACCESS_TOKEN=

# Optional: Team/Plus account ID
# CHATGPT_ACCOUNT_ID=

# Optional: browser cookies export (used when CHATGPT_ACCESS_TOKEN is empty)
COOKIES_FILE=cookies_1.json

# Server bind address (Go server)
HOST=localhost
PORT=8080

# Auto-click Allow/Always Allow when Custom GPT or MCP asks tool permission (default: true)
AUTO_APPROVE_TOOLS=true