# ─── ChatGPT credentials ─────────────────────────────────────────────────────
# Access token (eyJ… JWT) from https://chatgpt.com/api/auth/session
CHATGPT_ACCESS_TOKEN=
# Optional: Team/Plus account id (else derived from the JWT)
CHATGPT_ACCOUNT_ID=

# Browser-cookie export used as a fallback when CHATGPT_ACCESS_TOKEN is empty.
# Format: a JSON array exported by a browser cookie-export extension.
COOKIES_FILE=cookies_1.json

# ─── Server bind address ─────────────────────────────────────────────────────
HOST=localhost
PORT=8080

# ─── Account pool ────────────────────────────────────────────────────────────
# Pool persistence file. JSON, atomic-write.
ACCOUNTS_FILE=accounts.json
# How often the watcher refreshes tokens / restores limited accounts (minutes).
REFRESH_ACCOUNT_INTERVAL_MIN=5
# Per-account max in-flight image-generation slots.
IMAGE_ACCOUNT_CONCURRENCY=3
# When true: evict invalid tokens; when false: mark as 异常 and retry later.
AUTO_REMOVE_INVALID_ACCOUNTS=false
# When true: try password re-login if OAuth refresh fails (requires stored pwd).
AUTO_RELOGIN_AFTER_REFRESH=false
# Optional global proxy (e.g. http://user:pass@host:1080)
PROXY=

# ─── API authentication ──────────────────────────────────────────────────────
# Master key — required to call /admin/* endpoints and bootstrap API keys.
AUTH_KEY=
# When true: skip auth middleware entirely (NOT recommended in production).
DISABLE_AUTH=false

# ─── Storage backend ─────────────────────────────────────────────────────────
# json (default) | sqlite. All account / key data flows through this.
STORAGE_BACKEND=json
STORAGE_DIR=data
# Only consulted when STORAGE_BACKEND=sqlite.
SQLITE_PATH=

# ─── Backend behaviour ───────────────────────────────────────────────────────
# Auto-Approve when a Custom GPT or MCP tool requests permission.
AUTO_APPROVE_TOOLS=true